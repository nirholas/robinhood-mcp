# robinhood-mcp configuration.
#
# Copy to .env and fill in. Every variable below exists in the code; nothing
# here is aspirational. Defaults shown are the code's own defaults, chosen so
# that copying this file as-is cannot place an order.
#
# Create a credential at https://robinhood.com/account/crypto (web classic
# only: not the mobile app, not the new web UI). Generate the keypair with
# `npx robinhood-keygen`, register the PUBLIC key with Robinhood, and keep the
# private key here.


# ---------------------------------------------------------------------------
# Credentials (required by every binary)
# ---------------------------------------------------------------------------

# The API key Robinhood issues after you register your public key.
ROBINHOOD_CRYPTO_API_KEY=rh-api-00000000-0000-0000-0000-000000000000

# Base64-encoded 32-byte Ed25519 SEED. Not a 64-byte expanded keypair, not
# PKCS#8. Libraries that export `seed||publicKey` give 64 bytes and will fail
# every request. Treat this like a password: it authorizes trades.
ROBINHOOD_CRYPTO_PRIVATE_KEY=your-base64-32-byte-ed25519-seed


# ---------------------------------------------------------------------------
# API surface (optional)
# ---------------------------------------------------------------------------

# "v1" (default) or "v2". v2 adds fee-tier data to accounts and orders, needs
# an account_number on most endpoints (resolved automatically), moves
# estimated_price to /trading/, and reports "pending" where v1 reports
# "partially_filled". Any other value fails startup.
ROBINHOOD_CRYPTO_API_VERSION=v1

# Override the API host. There is no sandbox host to point this at; Robinhood
# publishes none. Leave unset unless you are proxying requests.
# ROBINHOOD_CRYPTO_BASE_URL=https://trading.robinhood.com


# ---------------------------------------------------------------------------
# Tool surface (optional, all binaries)
# ---------------------------------------------------------------------------

# Which capability modules to load, comma-separated, or "all".
#   market     quotes, holdings, account, pairs, order history   (on by default)
#   orders     the four native order types, cancel               (on by default, TRADES)
#   algo       the nine synthetic order types as durable jobs    (on by default, TRADES)
#   portfolio  cost basis, realized P&L, allocation, sizing      (on by default)
#   risk       exposure, limits, pre-trade checks, kill switch   (on by default, pauses jobs)
#   journal    fills, round trips, performance, CSV, reconcile   (off by default)
#   ops        health, clock skew, key check, supervisor status  (off by default)
#   dev        diagnostics, signature explanation, codegen       (off by default)
#
# Unset loads the default set. "all" loads everything, which spends context and
# measurably degrades tool choice: useful when exploring, poor in production.
# An unknown name fails startup rather than being silently dropped.
# ROBINHOOD_MCP_MODULES=market,orders,algo,risk

# Where durable jobs and the kill-switch state are stored.
# Default: ~/.robinhood-mcp/jobs.db
# ROBINHOOD_MCP_DB=/var/lib/robinhood-mcp/jobs.db

# How often the daemon's supervisor advances due jobs, in milliseconds.
# Default: 5000. Only read by robinhood-mcp-daemon.
# ROBINHOOD_MCP_TICK_MS=5000


# ---------------------------------------------------------------------------
# Trading (robinhood-mcp-trading and robinhood-mcp-daemon only)
#
# THERE IS NO SANDBOX. Every order is real money in a real brokerage account.
# The values below are the only thing between a misunderstood instruction and
# a real fill. Set them to numbers you are comfortable losing.
# ---------------------------------------------------------------------------

# Must be exactly "1" for the trading server or the daemon to start at all.
# Nothing else enables trading. Leave at 0 until you mean it.
ROBINHOOD_CRYPTO_ENABLE_TRADING=0

# Hard per-order USD ceiling, enforced in every mode. Fails closed: an order
# whose USD value cannot be determined up front is rejected, not assumed cheap.
# Must be a positive number.
ROBINHOOD_CRYPTO_MAX_ORDER_USD=100

# Cumulative USD this process may commit before refusing. In-memory and
# per-process: it resets on restart, so it is a runaway-loop brake rather than
# an accounting system or a hard budget. Unset means no cumulative cap.
# ROBINHOOD_CRYPTO_MAX_DAILY_USD=500

# When set, only these pairs may trade and everything else is refused.
# Comma-separated. Unset means every pair is allowed.
# ROBINHOOD_CRYPTO_SYMBOL_ALLOWLIST=BTC-USD,ETH-USD

# Set to "1" to reject every sell order.
# ROBINHOOD_CRYPTO_BUY_ONLY=1

# Set to "1" to execute immediately with no confirm step, for unattended
# strategies where no human is in the loop. In the default guarded mode (0), an
# order tool returns a priced preview and places nothing until a second call
# carries confirm: true.
#
# Every cap above STILL APPLIES in autonomous mode. It removes the human, not
# the ceiling: an unattended agent is exactly where a runaway order is most
# likely and least observed.
ROBINHOOD_CRYPTO_AUTONOMOUS=0

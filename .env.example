# Robinhood Crypto Trading API credentials.
# Create at https://robinhood.com/account/crypto (web classic only).
# Generate the keypair with: npx robinhood-crypto-keygen

ROBINHOOD_CRYPTO_API_KEY=rh-api-00000000-0000-0000-0000-000000000000
ROBINHOOD_CRYPTO_PRIVATE_KEY=your-base64-32-byte-ed25519-seed

# "v1" (default) or "v2". v2 adds fee-tier data to accounts and orders.
ROBINHOOD_CRYPTO_API_VERSION=v1

# --- Trading server only (robinhood-crypto-mcp-trading) ---
# Orders are REAL MONEY. Robinhood publishes no sandbox.
ROBINHOOD_CRYPTO_ENABLE_TRADING=0
ROBINHOOD_CRYPTO_MAX_ORDER_USD=100
# ROBINHOOD_CRYPTO_SYMBOL_ALLOWLIST=BTC-USD,ETH-USD
# ROBINHOOD_CRYPTO_BUY_ONLY=1
